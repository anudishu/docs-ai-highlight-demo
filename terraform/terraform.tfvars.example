# =============================================================================
# Copy this file to terraform.tfvars and edit values marked CHANGE.
#   cp terraform.tfvars.example terraform.tfvars
#
# Never commit terraform.tfvars (it is gitignored).
# =============================================================================

# >>> CHANGE (required): your GCP project ID
project_id = "your-gcp-project-id"

# >>> CHANGE (optional): region for GCS, Cloud Run, Firestore, Vertex embeddings
# Must support: Cloud Run, Firestore, Vertex AI, Eventarc
region = "asia-south1"

# >>> CHANGE (optional): prefix for service names, SAs, secrets (avoid clashes in shared projects)
name_prefix = "docs-highlight"

# >>> CHANGE (optional): set false if you already enabled APIs via scripts/enable-apis.sh
manage_project_services = true

# >>> CHANGE (optional): Gemini model for chat responses
gemini_model = "gemini-2.5-flash-lite"

# >>> CHANGE (optional): false = require IAM to call the API (no public internet)
allow_unauthenticated_api = true

# -----------------------------------------------------------------------------
# Gemini API key — use a SEPARATE file (also gitignored):
#
#   cp /dev/null secrets.auto.tfvars   # or create manually
#
# Add to secrets.auto.tfvars:
#
#   # >>> CHANGE (required for chat unless using Vertex-only mode)
#   gemini_api_key = "your-google-ai-studio-api-key"
#
# Get a key: https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Advanced (uncomment in terraform.tfvars if needed — see variables.tf)
# -----------------------------------------------------------------------------
# gemini_location      = "us-central1"   # Vertex Gemini region when no API key
# embedding_dimension  = 768
# upload_prefix        = "uploads/"
# extractions_prefix   = "extractions/"
